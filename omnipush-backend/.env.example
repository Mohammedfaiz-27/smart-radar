# FastAPI Configuration
DEBUG=false

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe Configuration (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# OpenAI Configuration (optional)
OPENAI_API_KEY=your_openai_api_key

# Image Search Configuration
# Provider options: 'serpapi' or 'google_custom_search' (default: google_custom_search)
IMAGE_SEARCH_PROVIDER=google_custom_search

# SerpAPI Configuration (optional, for legacy image search)
SERPAPI_KEY=your_serpapi_key

# Google Custom Search Configuration (recommended)
# Get API key from: https://console.cloud.google.com/apis/credentials
# Create Search Engine at: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_API_KEY=AIzaSyBnLKmnb5HZ1pV3b_3e-kjtVL7yj4SVcnI
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=b4d52c971e1de4533

# LLM-based HTML Generation Settings
ENABLE_LLM_HTML_GENERATION=true

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Legacy Configuration (for backward compatibility)
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FB_LONG_LIVED_TOKEN=your_facebook_long_lived_token

#   - USE_EXACT_NEWSCARD_TEMPLATE=true - Uses exact sample_newscard.html template
#   - ENABLE_LLM_HTML_GENERATION=true - Uses LLM to generate new templates